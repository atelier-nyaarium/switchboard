{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"outDir": "dist",
		"rootDir": "src",
		"declaration": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"types": ["bun-types"]
	},
	"include": ["src"],
	"exclude": [
		".claude",
		".cursor",
		".yarn",
		"build",
		"coverage",
		"node_modules",
		"volumes",
		".eslintrc.js",
		".pnp.cjs",
		".pnp.loader.mjs",
		"tsconfig.json"
	]
}
